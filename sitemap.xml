---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <!-- 메인 페이지 -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- 게임 허브 -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/games/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- 정보 페이지 -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/about.html</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/privacy.html</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/terms.html</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

  <!-- 블로그 포스트 -->
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}

  <!-- 컬렉션 페이지 -->
  {% for page in site.pages %}
  {% if page.url != '/sitemap.xml' and page.url != '/robots.txt' and page.url != '/feed.xml' and page.url != '/assets/search.html' %}
  {% if page.layout %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {% endif %}
  {% endif %}
  {% endfor %}

  <!-- 게임 개별 페이지 -->
  <url><loc>{{ site.url }}/games/yahtzee/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/tetris/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/omok/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/janggi/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/tap-battle/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/timing-hit/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/balloon-pop/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/ping-pong/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/rps/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/memory-numbers/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/color-sequence/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/number-race/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/games/nunchi/</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
</urlset>
